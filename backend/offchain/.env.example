# Network
SOLANA_NETWORK=mainnet-beta
RPC_URL=https://api.mainnet-beta.solana.com
# Optional fallback RPC list (comma-separated), used when RPC_URL has transient network errors.
# Example: RPC_URLS=https://api.mainnet-beta.solana.com,https://your-backup-rpc
RPC_URLS=

# Program & Token
# Fill after deployment
PROGRAM_ID=
USDC_MINT=
VAULT_PDA=
GLOBAL_STATE_PDA=

# Signer (cron/admin keypair path)
CRON_KEYPAIR=/root/.config/solana/authority.json

# Distribution rules (USDC has 6 decimals)
MIN_DEPOSIT_USD=100000000
EPOCH_DURATION_DAYS=7
MIN_PARTICIPANTS=20
WINNERS_PER_PARTICIPANTS=20
FEE_BPS=1000
REFUND_USD=50
FIXED_FEE_USD=100
PARTICIPANT_LOG_START_EPOCH=1

# Fee destinations (USDC token accounts)
DEV_FEE_ACCOUNT=
BUYBACK_FEE_ACCOUNT=
ADMIN_ALLOWED_WALLET=YOUR_ADMIN_WALLET_1,YOUR_ADMIN_WALLET_2

# Merkle distributor selection (streamflow | jupiter | custom)
DISTRIBUTOR_TYPE=streamflow
STREAMFLOW_PROGRAM_ID=
JUPITER_MERKLE_PROGRAM_ID=

# Price feeds
PYTH_PRICE_ACCOUNT=
SWITCHBOARD_FEED_ADDRESS=

# Storage / API
PROOF_BUCKET_PATH=/app/data/proofs
DISTRIBUTION_API_URL=https://yourdomain.com/api/distribution
