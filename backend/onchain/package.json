{
  "name": "reward-pool-onchain",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "lint:fix": "cargo fmt --all",
    "test": "anchor test",
    "build": "anchor build",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "deploy:mainnet": "anchor deploy --provider.cluster mainnet",
    "idl:init": "anchor idl init --filepath target/idl/reward_pool.json",
    "idl:upgrade": "anchor idl upgrade --filepath target/idl/reward_pool.json"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.98.4",
    "@types/chai": "^4.3.19",
    "@types/mocha": "^10.0.8",
    "chai": "^4.5.0",
    "mocha": "^10.7.3",
    "prettier": "^3.3.3",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.2"
  }
}
