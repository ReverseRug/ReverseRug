# Frontend Environment Variables
# API URL
VITE_API_URL=http://localhost:4000/api

# Solana Configuration
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com
VITE_SOLANA_NETWORK=mainnet-beta
VITE_LATE_JOIN_LOCK_SECONDS=86400

# Program IDs (replace with your actual program ID)
VITE_PROGRAM_ID=YOUR_PROGRAM_ID_HERE
VITE_USDC_MINT=YOUR_USDC_MINT_ADDRESS_HERE
VITE_ADMIN_WALLET=YOUR_ADMIN_WALLET_1,YOUR_ADMIN_WALLET_2
